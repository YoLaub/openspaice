[gd_resource type="Resource" script_class="DecisionCatalog" format=3]

[ext_resource type="Script" path="res://scripts/decisions/decision.gd" id="1_jlshk"]
[ext_resource type="Script" path="res://scripts/decisions/decision_option.gd" id="2_amejx"]
[ext_resource type="Script" path="res://scripts/decisions/decision_catalog.gd" id="3_xkbtk"]

[sub_resource type="Resource" id="Resource_e4rcg"]
